# Quizzy Springs pipeline — environment variables
#
# Copy this file to ".env" (no extension) and fill in your real key.
# The .env file is loaded automatically by script/paths.py at the start of
# every Python entry point (gen_voiceover.py, render.py, assemble.py,
# pipeline.py).
#
# To create your .env from this template:
#     cp .env.example .env
#     chmod 600 .env
#     # then edit .env and paste your real ElevenLabs key
#
# DO NOT commit .env to git. DO NOT paste it into a chat.
# If you ever leak the key, rotate it at:
#     https://elevenlabs.io  →  Profile  →  API Keys
#
# Higgsfield is NOT in here — it's configured via the Claude Code MCP
# connector (Settings → Connectors → Higgsfield) and needs no env var.

ELEVENLABS_API_KEY=sk_PASTE_YOUR_KEY_HERE
